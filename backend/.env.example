# Copie este arquivo para .env e preencha os valores reais
# cp .env.example .env

PORT=3333
NODE_ENV=production

# SQLite (padrão — sem configuração extra)
DB_PATH=/app/data/padaria.db

# Opcional: PostgreSQL (Neon, RDS, etc.)
# DATABASE_URL=postgres://user:password@host:5432/padaria

# CORS — URL do frontend (Vercel ou CloudFront)
CORS_ORIGIN=https://seu-app.vercel.app

# JWT (gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=troque-por-uma-chave-secreta-forte
